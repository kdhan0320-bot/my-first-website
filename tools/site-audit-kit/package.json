{
  "name": "site-audit-kit",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright-based responsive, accessibility, console, and link audit utilities for the portfolio workspace.",
  "scripts": {
    "test": "playwright test",
    "audit": "playwright test",
    "audit:headed": "playwright test --headed",
    "audit:ui": "playwright test --ui",
    "zip": "powershell -NoProfile -File \"scripts/create-zip.ps1\"",
    "clean": "node scripts/clean.js",
    "audit:detailed": "playwright test --config=playwright.detailed.config.ts",
    "audit:detailed:headed": "playwright test --config=playwright.detailed.config.ts --headed",
    "audit:routes": "playwright test --config=playwright.route-regression.config.ts",
    "audit:projects": "playwright test --config=playwright.projects.config.ts",
    "review:build": "node scripts/generate-portfolio-review.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1"
  }
}
